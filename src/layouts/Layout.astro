---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="School Helper - A fun learning app for kids" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;800&family=Varela+Round&family=Quicksand:wght@400;700&display=swap" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      // Apply saved font preference before first paint to avoid flash
      (function() {
        var FONTS = {
          'comic-sans': "'Comic Sans MS', 'Comic Sans', sans-serif",
          'system': "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
          'rounded': "'Nunito', 'Varela Round', 'Quicksand', system-ui, sans-serif",
        };
        var saved = localStorage.getItem('school-helper-font') || 'system';
        var family = FONTS[saved] || FONTS['system'];
        document.documentElement.style.setProperty('--font-fun', family);
      })();
    </script>
  </head>
  <body class="min-h-screen bg-kid-bg font-readable text-kid-text">
    <slot />
  </body>
</html>
